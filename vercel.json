{
  "framework": "vite",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    {
      "source": "/create",
      "destination": "/index.html"
    },
    {
      "source": "/markets/(.*)",
      "destination": "/index.html"
    }
  ]
}
